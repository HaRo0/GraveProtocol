$C = "../Common.ui";
Group {
  LayoutMode: Top;
  Background: #2a2a2a;
  Anchor: (Width: 800, Height: 600);
  Padding: (Full: 0);

  Label #Title {
    Padding: (Full: 0);
    Text: "Upgrade Tower";
    Style: (TextColor: #ffffff, HorizontalAlignment: Center);
  }

  Label #Balance {
    Padding: (Full: 0);
    Text: "Permanent Currency: 0";
    Style: (TextColor: #f0e080, HorizontalAlignment: Center);
  }

  Group #ItemList {
    LayoutMode: TopScrolling;
    Anchor: (Height: 496);
  }

  $C.@TextButton #Cancel {
    Padding: (Full: 0);
    Text: "Close";
  }
}
